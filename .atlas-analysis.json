  "keyFeatures": [
    "Dedicated REST clients for Spot, Derivatives, Institutional, and Partner APIs",
    "Unified WebsocketClient for all Kraken WebSocket markets (Spot & Futures)",
    "WebsocketAPIClient for REST-like trading over persistent WebSocket connections",
    "Full TypeScript support with strongly typed requests and responses",
    "Automatic WebSocket reconnection, resubscription, and heartbeat management",
    "Browser-compatible HMAC signature mechanism",
    "Dual ESM and CJS module support",
    "Proxy support via axios",
    "Testnet/demo environment support for Derivatives",
    "Built-in nanoid-based order ID generation"
  ],
